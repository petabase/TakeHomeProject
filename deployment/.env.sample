# ─────────────────────────────────────────────────────────────
# TTB Label Verifier — Environment Variables
# ─────────────────────────────────────────────────────────────
# 1. Copy this file to .env in the project root:
#       cp .env.sample .env
# 2. Replace placeholder values with your actual keys
# 3. NEVER commit .env to git — it is already in .gitignore
# ─────────────────────────────────────────────────────────────

# Google Gemini API key (free tier)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# App settings (optional — defaults shown)
APP_ENV=development
APP_PORT=8000
